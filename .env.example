# Database
POSTGRES_USER=tripplanner
POSTGRES_PASSWORD=tripplanner_secret
POSTGRES_DB=tripplanner
DB_PORT=5432

# Application
APP_PORT=8081
JWT_SECRET=change-this-to-a-long-random-string

# Mapping services (free public APIs — no API key required)
OSRM_URL=https://router.project-osrm.org
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Optional: free API key from https://openrouteservice.org/dev/#/signup
# Enables "Avoid Highways" scenic routing (public OSRM does not support this)
# ORS_API_KEY=your-openrouteservice-api-key

# External service (optional — improves Tesla supercharger lookup rate limits)
# OCM_API_KEY=your-openchargemap-api-key
