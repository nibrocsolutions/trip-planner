# Database
POSTGRES_USER=tripplanner
POSTGRES_PASSWORD=tripplanner_secret
POSTGRES_DB=tripplanner
DB_PORT=5432

# Application
APP_PORT=8081
JWT_SECRET=change-this-to-a-long-random-string

# Self-hosted map services (defaults point to Docker containers)
OSRM_URL=http://osrm:5000
NOMINATIM_URL=http://nominatim:8080
NOMINATIM_PASSWORD=nominatim_secret
NOMINATIM_SHM_SIZE=1g

# Map data — used by scripts/setup-map-data.sh and the Nominatim/OSRM containers
# Pick a region from https://download.geofabrik.de/ (smaller = faster on Raspberry Pi)
MAP_REGION_URL=https://download.geofabrik.de/north-america/us/delaware-latest.osm.pbf
MAP_BASENAME=region

# Docker images (override if needed)
# OSRM_IMAGE=ghcr.io/project-osrm/osrm-backend:latest
# NOMINATIM_IMAGE=mediagis/nominatim:4.4

# External service (optional — Tesla supercharger lookup still uses OpenChargeMap)
# OCM_API_KEY=your-openchargemap-api-key
